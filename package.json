{
  "name": "yourcall",
  "displayName": "YourCall",
  "description": "极简 Coding Agent 扩展 — 不为改变你的习惯，只为服务你的Agent",
  "version": "0.1.0",
  "publisher": "",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:aiCompletion.openSidebar",
    "onView:aiCompletion.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiCompletion.openSidebar",
        "title": "Open AI Completion Sidebar"
      },
      {
        "command": "aiCompletion.configureApiKey",
        "title": "Configure AI Completion API Key"
      },
      {
        "command": "aiCompletion.selectModel",
        "title": "AI Completion: Select Model"
      },
      {
        "command": "yourcall.copyCode",
        "title": "复制代码位置给 AI"
      },
      {
        "command": "yourcall.copyFilePath",
        "title": "复制文件路径给 AI"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "yourcall.copyCode",
          "group": "navigation@1.5"
        },
        {
          "when": "!editorHasSelection",
          "command": "yourcall.copyFilePath",
          "group": "navigation@1.6"
        }
      ],
      "explorer/context": [
        {
          "command": "yourcall.copyFilePath",
          "group": "navigation@1.6"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-completion",
          "title": "AI Completion",
          "icon": "media/activity-bar.svg"
        }
      ]
    },
    "views": {
      "ai-completion": [
        {
          "type": "webview",
          "id": "aiCompletion.sidebar",
          "name": "AI Completion",
          "icon": "$(lightbulb)"
        },
        {
          "type": "webview",
          "id": "aiCompletion.agent",
          "name": "Agent CLI",
          "icon": "$(terminal)"
        }
      ]
    },
    "configuration": {
      "title": "AI Completion",
      "properties": {
        "aiCompletion.apiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for the API endpoint"
        },
        "aiCompletion.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model name to use for completions"
        },
        "aiCompletion.agentCommand": {
          "type": "string",
          "default": "",
          "description": "Agent CLI 命令，如 claude, opencode, aider。留空则在侧边栏选择"
        },
        "aiCompletion.maxFileLines": {
          "type": "number",
          "default": 500,
          "description": "Maximum number of lines to include from a file"
        },
        "aiCompletion.maxOpenFiles": {
          "type": "number",
          "default": 10,
          "description": "Maximum number of open files to consider for context"
        },
        "aiCompletion.suggestionCount": {
          "type": "number",
          "default": 3,
          "description": "Number of suggestions to generate"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "vscode:prepublish": "npm run build",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
