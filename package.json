{
  "name": "yourcall",
  "displayName": "YourCall",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "yourcall.openSidebar",
        "title": "%cmd.openSidebar.title%"
      },
      {
        "command": "yourcall.configureApiKey",
        "title": "%cmd.configureApiKey.title%"
      },
      {
        "command": "yourcall.selectModel",
        "title": "%cmd.selectModel.title%"
      },
      {
        "command": "yourcall.copyCode",
        "title": "%cmd.copyCode.title%"
      },
      {
        "command": "yourcall.copyFilePath",
        "title": "%cmd.copyFilePath.title%"
      },
      {
        "command": "yourcall.installNodePty",
        "title": "%cmd.installNodePty.title%"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "yourcall.copyCode",
          "group": "navigation@1.5"
        },
        {
          "when": "!editorHasSelection",
          "command": "yourcall.copyFilePath",
          "group": "navigation@1.6"
        }
      ],
      "explorer/context": [
        {
          "command": "yourcall.copyFilePath",
          "group": "navigation@1.6"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yourcall",
          "title": "Your Call",
          "icon": "media/activity-bar.svg"
        }
      ]
    },
    "views": {
      "yourcall": [
        {
          "type": "webview",
          "id": "yourcall.sidebar",
          "name": "Your Call",
          "icon": "$(lightbulb)"
        },
        {
          "type": "webview",
          "id": "yourcall.agent",
          "name": "Agent CLI",
          "icon": "$(terminal)"
        }
      ]
    },
    "configuration": {
      "title": "Your Call",
      "properties": {
        "yourcall.apiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for the API endpoint"
        },
        "yourcall.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model name to use for completions"
        },
        "yourcall.agentCommand": {
          "type": "string",
          "default": "",
          "description": "Agent CLI 命令，如 claude, opencode, aider。留空则在侧边栏选择"
        },
        "yourcall.maxFileLines": {
          "type": "number",
          "default": 500,
          "description": "Maximum number of lines to include from a file"
        },
        "yourcall.maxOpenFiles": {
          "type": "number",
          "default": 10,
          "description": "Maximum number of open files to consider for context"
        },
        "yourcall.suggestionCount": {
          "type": "number",
          "default": 3,
          "description": "Number of suggestions to generate"
        },
        "yourcall.enableReasoning": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI model deep reasoning (reasoning_effort). Disable for faster responses on simple tasks"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "vscode:prepublish": "npm run build",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
